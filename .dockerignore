# ===========================================
# Docker 构建排除文件（后端镜像）
# ===========================================

# Python 缓存
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
build/

# Git
.git/
.gitignore

# 文档（保留README）
*.md
!README.md

# IDE
.idea/
.vscode/
*.swp
*.swo

# 前端目录（后端构建不需要）
frontend/

# 本地数据文件（使用volume持久化）
uploads/
*.db

# 环境变量（运行时注入）
.env
.env.local

# Docker配置文件（不需要复制进镜像）
docker-compose*.yml
Dockerfile*
.dockerignore

# 日志和临时文件
*.log
*.tmp
*.bak

# 系统文件
.DS_Store
Thumbs.db
