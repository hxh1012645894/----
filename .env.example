# TextIn API 配置（用于文档解析）
TEXTIN_APP_ID=your_textin_app_id_here
TEXTIN_SECRET_CODE=your_textin_secret_code_here

# DeepSeek API 配置（用于智能审核）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 提示词优化 LLM API 配置（通用 OpenAI 协议）
PROMPT_LLM_API_KEY=your_prompt_llm_api_key_here
PROMPT_LLM_BASE_URL=https://your-llm-api-url/v1
PROMPT_LLM_MODEL=your_model_name

# 应用配置
DATA_DIR=data
DB_FILE=audit_batches.db

# 后端服务配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000