# ===========================================
# ISO 体系智能审核系统 - 环境变量配置
# ===========================================

# TextIn API 配置（用于文档解析OCR）
TEXTIN_APP_ID=your_textin_app_id_here
TEXTIN_SECRET_CODE=your_textin_secret_code_here

# DeepSeek API 配置（用于智能审核分析）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 提示词优化 LLM API 配置（通用 OpenAI 协议）
PROMPT_LLM_API_KEY=your_prompt_llm_api_key_here
PROMPT_LLM_BASE_URL=https://your-llm-api-url/v1
PROMPT_LLM_MODEL=glm-4.7

# ===========================================
# 以下配置通常不需要修改（由 config.py 自动设置为 backend 目录下）
# ===========================================

# 目录配置（本地开发时由 config.py 自动计算绝对路径）
# UPLOAD_DIR、DATA_DIR、DB_FILE、ROUTING_DICT_PATH 均无需手动设置

# 后端服务配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8002